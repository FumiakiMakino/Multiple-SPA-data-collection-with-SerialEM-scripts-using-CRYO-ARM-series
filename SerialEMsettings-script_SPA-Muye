    def on_save_as(self):
        try:
            if sem is None:
                raise RuntimeError("serialem module not available")
   
            # (1) current setting/script paths
            sem.ReportSettingsFile()
            current_setting = sem.GetVariable("RepVal1")
            sem.ReportSettingsFile()
            current_script  = sem.GetVariable("RepVal2")
   
            if not current_script or not os.path.isfile(current_script):
                raise FileNotFoundError(f"Script file not found (RepVal2): {current_script}")
            if not current_setting or not os.path.isfile(current_setting):
                raise FileNotFoundError(f"Setting file not found (RepVal1): {current_setting}")

            # (2) backup to .bak (in current files' folder)
            cur_folder = os.path.dirname(current_script)
            set_base = os.path.splitext(os.path.basename(current_setting))[0]
            scr_base = os.path.splitext(os.path.basename(current_script))[0]
            date_str = self.var_date.get().strip()
            if not re.fullmatch(r"\d{6}", date_str):
                date_str = _today_yymmdd()
            _copy_as_bak(current_setting, set_base, cur_folder, date_str)
            _copy_as_bak(current_script,  scr_base, cur_folder, date_str)

            # (3) choose destination folder first
            initdir = cur_folder if os.path.isdir(cur_folder) else (DEFAULT_DIR if os.path.isdir(DEFAULT_DIR) else os.getcwd())
            target_folder = filedialog.askdirectory(
                title="Choose destination folder for new setting/script files",
                initialdir=initdir
            )
            if not target_folder:
                self._set_status("Save canceled (folder not chosen).")
                return

            # (4) propose default filenames (editable in save dialogs)
            use_name = self.var_name.get().strip() if self.use_name.get() else ""
            suffix = f"_{use_name}" if use_name else ""
            def_set_name = f"{set_base}{suffix}_{date_str}.txt"
            def_scr_name = f"serialEMscripts{suffix}_{date_str}.txt"

            # (5) ask filenames (setting then script) within the chosen folder
            new_settings_path = filedialog.asksaveasfilename(
                title="Save settings as...",
                initialdir=target_folder,
                initialfile=def_set_name,
                defaultextension=".txt",
                filetypes=[("Text files","*.txt"),("All files","*.*")]
            )
            if not new_settings_path:
                self._set_status("Save canceled (settings filename not chosen).")
                return

            new_script_path = filedialog.asksaveasfilename(
                title="Save EMProperties script as...",
                initialdir=target_folder,
                initialfile=def_scr_name,
                defaultextension=".txt",
                filetypes=[("Text files","*.txt"),("All files","*.*")]
            )
            if not new_script_path:
                self._set_status("Save canceled (script filename not chosen).")
                return

            # (6) load current script
            with open(current_script, "r", encoding="utf-8") as f:
                src_script = f.read()

            # (7) build replacement map from UI
            replace_map = _build_replacement_map_for_save(self.model)
            # fill Record_* with dummy if allowed and empty
            if DUMMY_RECORD_ALLOWED:
                for k, dv in DUMMY_RECORD_VALUES.items():
                    if replace_map.get(k, "").strip() == "":
                        replace_map[k] = dv

            # (8) replace assignments inside EMProperties::LoadAdditionalProperties
            def _do_replace(block_text):
                return _replace_assignments_in_text(block_text, replace_map, case_sensitive=True, debug=False)
            out_script = _replace_in_macro_block_robust(src_script, "EMProper", _do_replace)

            # (9) rewrite cmd_Mag* filenames (keep path)
            def _do_cmd_rewrite(block_text):
                return _rewrite_cmd_mag_filenames(block_text, replace_map)
            out_script = _replace_in_macro_block_robust(out_script, "LoadAdditionalProperties", _do_cmd_rewrite)

            # (10) write new EMProperties script with header
            newline = "\r\n"
            header = (
                f"### Auto-saved by Settings Bundler (Save As){newline}"
                f"### Based on: {os.path.basename(current_script)}{newline}"
                f"### Linked settings: {os.path.basename(new_settings_path)}{newline}"
                f"{newline}"
            )
            with open(new_script_path, "w", encoding="utf-8") as f:
                f.write(out_script) #edit by FM

            # (11) load current settings, replace ScriptPackagePath with new script path, and save
            with open(current_setting, "r", encoding="utf-8") as f:
                src_settings = f.read()
            out_settings = _replace_script_package_path(src_settings, new_script_path)
            with open(new_settings_path, "w", encoding="utf-8") as f:
                f.write(out_settings)
   
            messagebox.showinfo(
                "Save As",
                "Saved:"+"\n"
                f"  new setting : {new_settings_path}"+"\n"
                f"  new script  : {new_script_path}"
            )
            self._set_status("Save As completed.")
   
        except Exception as e:
            messagebox.showerror("Save As", str(e))
            self._set_status("Save As failed.")
      
