ScriptName SetNumAcquireMovie

# ========= Total planned record images and turn off acquire beyond threshold =====
# Summary:
# - Estimate shots-per-hole from current plan
# - Walk Navigator table in order, keep Acquire ON until cumulative images exceeds setTotal
# - Turn Acquire OFF for all subsequent items (unless dryrun=1)
#
# Notes:
# - Assumes RepVal3/RepVal1 gives shots-per-hole (i.e., MultiShot etc. reflected)
# - Requires Navigator items to have NavNumHoles set (holes count per item)
#
# Date: 2025-12-24
# Author: F.M. (JEOL Ltd.)
# License: MIT License
# ----------------------------------------------------------------------

# ======== Parameters ==========
setTotal = 10000   # total number of Record movies to keep (estimate)
dryrun = 0         # 1: do not modify acquire flag, just report; 0: apply changes
# ==============================

# ---- get current acquisition summary ----
ReportNumHoleAcquire

Echo ========== Summary for planned acquisition ========
Echo Acquire items count: $RepVal2
Echo Total holes to be acquired: $RepVal1
Echo Estimated total Record movies: $RepVal3

# ---- guard against division by zero ----
totalHoles = $RepVal1
totalMovies = $RepVal3

If ( $totalHoles <= 0 )
   Echo No holes are planned (RepVal1 <= 0). Nothing to do.
   Exit
EndIf

# shots-per-hole (can be fractional)
shotPerHole = $totalMovies / $totalHoles
Echo shotsPerHole = $shotPerHole

# ---- walk Navigator table in order, keep items until cumulative exceeds setTotal ----
ReportNumTableItems
nItems = $RepVal1

cumImages = 0
crossed = 0
lastKeepIndex = 0
keptAcquire = 0
turnOff = 0

SuppressReports 1
DoLoop its 1 $nItems
   # Read the item and its hole count
   ReportOtherItem $its
   holesHere = $navNumHoles

   If ( $holesHere <= 0 )
      Continue
   EndIf

   imageHere = $holesHere * $shotPerHole

   If ( $crossed == 0 )
      cumImages = $cumImages + $imageHere
      lastKeepIndex = $its
      keptAcquire = $keptAcquire + 1

      If ( $cumImages > $setTotal )
         crossed = 1
         # (This item is still kept, as "first exceeding item")
      EndIf
   Else
      If ( $dryrun == 0 )
         SetItemAcquire $its 0
      EndIf
      turnOff = $turnOff + 1
   EndIf
EndLoop
SuppressReports 0

# ---- report after modifications ----
ReportNumHoleAcquire
Echo ========== Summary after applying threshold ========
Echo Kept acquire items (count): $keptAcquire
Echo Turned off acquire items (count): $turnOff
Echo Last kept item index: $lastKeepIndex
Echo Acquire items count (now): $RepVal2
Echo Total holes to be acquired (now): $RepVal1
Echo Estimated total Record movies (now): $RepVal3
EndMacro
