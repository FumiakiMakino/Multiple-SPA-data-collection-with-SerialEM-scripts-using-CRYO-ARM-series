ScriptName FindSquareContour

# ----------------------------------------------------------------------
# Summary (one line):
# From a square map in buffer E, iteratively run AutoContourGridSquares with increasing histogram threshold until exactly one square polygon is produced in the Navigator, deleting extra polygons when too many are found.
#
# What this script is trying to do (overview):
# 1) Open the Navigator and record how many items already exist (baseCount).
# 2) Load a Navigator map from buffer E (your square map) so contouring operates on that map.
# 3) Try up to 10 iterations:
#    - Run AutoContourGridSquares using a histogram fraction threshold (histFrac).
#    - Read the autocontour statistics (LowCut, UpCut, Med).
#    - Convert detected squares into polygons via MakePolygonsAtSquares (with minSizeCut/sd).
#    - Count how many Navigator items were added compared to baseCount:
#        * If +1 item: success → stop.
#        * If >+1 items: delete those new items and try again (aiming to leave only one).
#        * If 0 items: increase histFrac and retry.
# 4) After the loop, if it never hit exactly +1 item, it runs the contouring once more and then deletes extras.
#
# Important issues / likely bugs to fix:
# - Variable typo: you define “histFrac = $starthistFrac” but call AutoContourGridSquares with “$histFracVar”.
#   That variable is never defined, so AutoContourGridSquares is probably using 0 or failing silently depending on SerialEM behavior.
#   It should likely be:  AutoContourGridSquares $buf 1500 $histFrac 0 $SizeMin $SizeMax 0
#
# - Deleting logic assumes “diff” is correct in the final fallback block, but if the loop exits by “histFrac > 1.0”,
#   “diff” may be stale or undefined. You should recompute nowCount/diff after the final run before deleting.
#
# - You set minSizeCut twice:
#     minSizeCut = -1 (earlier)
#     minSizeCut = 10 (later)
#   The first assignment is overwritten; keep only one to avoid confusion.
#
# - You define a size-step logic (SizeMin/SizeMax/minSizeStep/maxSizeCut) but never actually update SizeMin/SizeMax in the loop.
#   Right now only histFrac changes; if you intended to sweep SizeMin too, you need to modify it each iteration.
#
# - SuspendNavRedraw 1 is inside the loop, but SuspendNavRedraw 0 is only after the loop.
#   If an Exit happens inside the loop (not present now), redraw would remain suspended. Not critical here but keep in mind.
#
# Parameter notes:
# - buf = E: expects the square montage/map to already be in buffer E.
# - starthistFrac: starting threshold; if too low, you get too many squares; if too high, you may get none.
# - minSizeCut / sd: passed to MakePolygonsAtSquares; your comments say “minSizeCut small is better” and “sd larger is better”.
#   These likely affect polygon filtering/merging; confirm in SerialEM docs for MakePolygonsAtSquares.
#
# Author: (your convention) F.M. (JEOL Ltd.)
# Date: 2025-12-24
# License: MIT License
# ----------------------------------------------------------------------

# ===== Parameters =====
buf = E             # buffer containing the square map (A or B)
reduceTo = 1.2       # autocontour reduction target (microns per pixel if <10)
starthistFrac = 0.1       # histogram fraction threshold for AutoContourGridSquares
SizeMin = 20   # start from a large minimum linear size (microns)
SizeMax = 130     # lower bound of minimum size to try
minSizeStep = -5     # step for minimum size (negative to decrease)
maxSizeCut = -1      # maximum size cutoff; -1 to use stored/dialog
verboseLog = 1       # 1 to echo progress

minSizeCut = 10 #Small value is beter
sd = 300 #larger value is beter

# ===== Prep =====
OpenNavigator
ReportNumTableItems
baseCount = $RepVal1

# =================
LoadNavMap $buf

histFrac = $starthistFrac

Loop 10
   flg = 0
   SuspendNavRedraw 1

   Try 
      AutoContourGridSquares $buf 1500 $histFracVar 0 $SizeMin $SizeMax 0
      ReportAutocontourStats LowCut UpCut Med
      MakePolygonsAtSquares $LowCut $UpCut $minSizeCut $sd 1 0.0
   Catch 
      echo Failed in Contour threshold $histFrac
   EndTry 

   ReportNumTableItems 
   nowCount = $reportedValue1
   diff = $nowCount  - $baseCount
   if $diff == 1 
      echo Finish for making polygon
      flg = 1
      Break 
   ElseIf $diff > 1 
      # Delete any items created in previous iteration
      Loop $diff
         DeleteNavigatorItem -1
      EndLoop 
      echo Cotinue find until one polygon
   Else
      histFrac = $histFrac + 0.15
      If ($histFrac > 1.0 )
         Break 
      Endif 
   Endif 
   
EndLoop 

SuspendNavRedraw 0
If $flg != 1
   AutoContourGridSquares $buf 1500 $histFracVar 0 $SizeMin $SizeMax 0
   ReportAutocontourStats LowCut UpCut Med
   MakePolygonsAtSquares $LowCut $UpCut $minSizeCut $sd 1 0.0

      Loop ($diff - 1)
         DeleteNavigatorItem -2
      EndLoop 

Endif 
EndMacro
