def _replace_script_package_path(settings_text: str, new_script_fullpath: str) -> str:
    """
    Replace (or append if missing) 'ScriptPackagePath <path>' with the new full path.
    Accept any whitespace after the token (tabs/spaces); normalize to single space.
    """
    if not isinstance(settings_text, str):
        settings_text = "" if settings_text is None else str(settings_text)

    newline = "\r\n" if "\r\n" in settings_text else "\n"
    lines = settings_text.splitlines(keepends=True)
    replaced = False
    out_lines = []

    for ln in lines:
        idx = ln.find("ScriptPackagePath")
        if idx == -1:
            out_lines.append(ln)
            continue

        # strip EOL
        if ln.endswith("\r\n"):
            end = "\r\n"; core = ln[:-2]
        elif ln.endswith("\n"):
            end = "\n"; core = ln[:-1]
        else:
            end = ""; core = ln

        head = core[:idx]
        token = "ScriptPackagePath"
        rest = core[idx+len(token):]

        # swallow any whitespace after the token (tabs or spaces)
        i = 0
        while i < len(rest) and rest[i].isspace():
            i += 1

        new_core = head + token + " " + new_script_fullpath
        out_lines.append(new_core + end)
        replaced = True

    if not replaced:
        # ensure we end with newline before appending a fresh line
        if out_lines and not (out_lines[-1].endswith("\n") or out_lines[-1].endswith("\r")):
            out_lines[-1] = out_lines[-1] + newline
        out_lines.append(f"ScriptPackagePath {new_script_fullpath}{newline}")

    return "".join(out_lines)

