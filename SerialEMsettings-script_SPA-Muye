ScriptName BeforeTakeSquares

# ----------------------------------------------------------------------
# Summary (one line):
# Prepare microscope/camera for multi-square acquisition (optional tilt + Koehler Z handling), then auto-center each square by map-map alignment before imaging.
#
# Author: F.M. (JEOL Ltd.)
# Date: 2025-12-24
#
# License: MIT License
# ----------------------------------------------------------------------
#===================================================================
# Script for taking multiple square images. 
# --------------------------------------------------------------------------------------------------------------------
# <How to run>
# 1. Take square position by "Add points" in Multiple window
# --------------------------------------------------------------------------------------------------------------------
#===================================================================

# =================
# Parameters
# =================
exp_time = 5 #[sec]
binFactor = 2
CLapt_before = 1 # CLapt for taking square. 0: Remove, 1: No.1, 2: No.2, 3:No.3, 4:No.4
do_tilt = 0 # how much degree you need, 0 is none
do_centerSquare = 0 # Do you want to shift to center of square, 0 is none.

# ============ Parameters for MoveToSquarae============
maxShiftUm = 100 #[um], max shift search
pctScale = 20 # 0: use default rotation search, 10 for 10 percent
maxRotDeg = -1 # -1: default, 10 for plus-minus 10 deg
inhibitShift = 1 #1: do not apply shift 
thr_shift2maker = 0  #[um] Whether to apply the threshold for shift to maker, <=0: do not apply shift to maker,  
# =====================================


# ============================
# Main
# ============================

CallFunction BeforeTakeSquares::Core

# Set camera parameters
SetExposure R $exp_time
SetProcessing R 2 # 2:gain reference
SetDoseFracParams R 0 0 0 0 0    

# Reset tilt
TiltTo 0 
TiltTo 0

#RestoreCameraSet R

# =============== Tilt operation for square 1=============
If $do_tilt != 0
   Eucentricity 1 #rough
   TiltTo ($do_tilt + 5)
   Delay 1 sec 
   TiltTo $do_tilt
   Delay 1 sec 
   TiltTo $do_tilt
   Delay 5 sec
Endif 

CallFunction EMProperties::LoadAdditionalProperties

# If koehler illumination apply offset Z
#==========koehler_z_offset============
If ($koehler_z_offset != 0)
   Echo ===> Adjust eucentircity for whole squares
   ReportStageXYZ 
   z = $RepVal3
   ht = $z  + $koehler_z_offset 
   if $ht < -210 
      echo Caution! over z stage, -210 and stop. Please Skip this grid for Koehler mode.
   Else
      MoveStage 0 0 $koehler_z_offset #test
      UpdateGroupZ 
   Endif 
Else
   Echo ===> Skip adjust eucentircity for whole squares
Endif 

# =============== Tilt operation for square 2=============
If $do_tilt != 0 
   # =============== Tilt operation stage shift=============
   ReportTiltAngle tiltang
   diffy = SIN ( $tiltang ) * $koehler_z_offset 
   Delay 3 sec
   MoveStage 0 $diffy 0
Endif 
#=========================


# =================== Go to Square center ==============
If $do_centerSquare == 1
  CallFunction BeforeTakeSquares::MoveToSquareCenter
EndIf

# ================================================

