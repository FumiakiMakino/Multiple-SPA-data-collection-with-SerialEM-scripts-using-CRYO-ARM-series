ScriptName FunctionOfAdjustFOV_byDrag-nonPython
# ----------------------------------------------------------------------
# Summary (1 line):
#   Calibrate and apply JEOL FLA1 deflector so the image can be re-centered by “dragging” the view (non-Python + Python helper).
#
# Overview:
#   This package consists of:
#     1) A non-Python SerialEM function set that reads JEOL IS1/FLA1 values and performs a 2-point calibration
#        (FLA change -> observed IS change) to compute an IS->FLA transform matrix.
#     2) A Python script that shows View images, waits for the user to drag the image (Image Shift),
#        then converts the IS delta into the required FLA1 correction and applies it via JEOL plugins.
#   Intended use:
#     - Run at Square/Atlas magnifications to refine FOV alignment interactively and save lens states as needed.
#
# Date: 2025-12-25
# Author: F.M. (JEOL Ltd.)
# License: MIT License
# ----------------------------------------------------------------------

#Function for Adjust FOV by Drag non-python functions

# function for GetIS 
Function GetIS
   Plugin JEOL GetIS1
   oorgIS1x = $JEOLVal1
   oorgIS1y = $JEOLVal2
   Return $oorgIS1x $oorgIS1y 
EndFunction 

#function for GetFLA
Function GetFLA
   Plugin JEOL GetFLA1
   curFLA1x = $JEOLVal1
   curFLA1y = $JEOLVal2
   Return $curFLA1x $curFLA1y
EndFunction 


#function for FLA calibration
Function FLAcalibration
   
   # parameters
   
   deltaFLA1x = 600  #dec
   deltaFLA1y = 100  #dec
   
   
   deltaFLA1x2 = -200  #dec
   deltaFLA1y2 = -500  #dec
   
   # ----------go ---------------
   
   echo  ----------go ---------------
   
   
   #Call CallSquareMag
   SetColumnOrGunValve 1
   
   SetImageShift 0 0
   
   View
   Copy A F
   
   #get FLA1
   Plugin JEOL GetFLA1
   
   curFLA1x = $JEOLVal1
   curFLA1y = $JEOLVal2
   
   
   # ========== 1st ============
   FLA1x = $curFLA1x + $deltaFLA1x 
   FLA1y = $curFLA1y + $deltaFLA1y 
   
   echo  1st ------- Plus $deltaFLA1x  $deltaFLA1y 
   
   # move image by FLA1
   Plugin JEOL SetDecFLA1 $FLA1x $FLA1y
   
   Plugin JEOL GetIS1
   
   orgIS1x = $JEOLVal1
   orgIS1y = $JEOLVal2
   
   View
   AlignTo F 
   Plugin JEOL GetIS1
   curIS1x = $JEOLVal1
   curIS1y = $JEOLVal2
   delay 1 sec
   
   # reset image shift
   ClearAlignment 1
   SetImageShift 0 0
   
   deltaIS1x = $curIS1x - $orgIS1x
   deltaIS1y = $curIS1y - $orgIS1y
   echo deltaISx  ISy FLA1x FLA1y  $deltaIS1x $deltaIS1y $deltaFLA1x   $deltaFLA1y 
   
   # reset FLA1
   Plugin JEOL SetDecFLA1 $curFLA1x  $curFLA1y
   
   delay 3 sec
   
   # ========== 2nd ============
   FLA1x = $curFLA1x + $deltaFLA1x2 
   FLA1y = $curFLA1y + $deltaFLA1y2 
   
   echo 2nd ------- Plus $deltaFLA1x2  $deltaFLA1y2 
   
   # move image by FLA1
   Plugin JEOL SetDecFLA1 $FLA1x $FLA1y
   
   Plugin JEOL GetIS1
   
   orgIS1x = $JEOLVal1
   orgIS1y = $JEOLVal2
   
   View
   AlignTo F 
   Plugin JEOL GetIS1
   curIS1x = $JEOLVal1
   curIS1y = $JEOLVal2
   delay 1 sec
   
   # reset image shift
   ClearAlignment 1
   SetImageShift 0 0
   
   deltaIS1x2 = $curIS1x - $orgIS1x
   deltaIS1y2 = $curIS1y - $orgIS1y
   echo deltaISx  ISy FLA1x FLA1y  $deltaIS1x2 $deltaIS1y2 -$deltaFLA1x  -$deltaFLA1y
   
   fx1 = $deltaFLA1x
   fy1 = $deltaFLA1y
   fx2 = $deltaFLA1x2
   fy2 = $deltaFLA1y2
   ix1 = $deltaIS1x
   iy1 = $deltaIS1y
   ix2 = $deltaIS1x2
   iy2 = $deltaIS1y2
   
   
   # reset FLA1
   Plugin JEOL SetDecFLA1 $curFLA1x  $curFLA1y
   
   #((a,b)
   #(c,d))
   
   a = ( $fx1 * $iy2 - $fx2 * $iy1 ) / ( $ix1 * $iy2 - $ix2 * $iy1 )
   b = ( $fx2 * $ix1 - $fx1 * $ix2 ) / ( $ix1 * $iy2 - $ix2 * $iy1 )
   c = ( $fy1 * $iy2 - $fy2 * $iy1 ) / ( $ix1 * $iy2 - $ix2 * $iy1 )
   d = ( $fy2 * $ix1 - $fy1 * $ix2 ) / ( $ix1 * $iy2 - $ix2 * $iy1 )
   
   echo ((a,b),(c,d)) = $a $b $c $d
   
   
   Return $a $b $c $d

EndFunction 
EndMacro
