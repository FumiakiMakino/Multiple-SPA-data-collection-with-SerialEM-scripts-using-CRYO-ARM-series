ScriptName DeleteAllPolygons

# ----------------------------------------------------------------------
# Summary (one line):
# Scan all Navigator items, collect indices of polygon items, then delete them (in reverse order) so index shifts don’t break deletion.
#
# What it does (overview):
# 1) Get total number of Navigator table items (numItems).
# 2) If 0, print a message and effectively do nothing (note: currently it does not Exit).
# 3) Loop i=1..numItems:
#    - ReportOtherItem i to read item properties into RepVal’s.
#    - RepVal5 is treated as “type”; type==1 is assumed to mean “polygon”.
#    - Store polygon indices into an array (polyIdex).
# 4) Delete polygons in reverse order using DeleteNavigatorItem idx.
#
# Date: 2025-12-24
# Author: F.M. (JEOL Ltd.)
# License: MIT License
# ----------------------------------------------------------------------

# ========= Delete all polygon in the Navigator file =====

ReportNumTableItems 
numItems = $RepVal1
echo $numItems iters
If ($numItems == 0 )
   Echo Navigator is empy, nothing to delete.
Endif 

#loop 
SuspendNavRedraw 
NewArray polyIdex 0 0

DoLoop i 1 $numItems
   Try 
      ReportOtherItem $i
   Catch 
      Break 
   EndTry 
   type = $RepVal5
   If ($type == 1) #if polygon
      echo Polystong $i
      AppendToArray polyIdex $i
   Endif 
EndLoop 
SuspendNavRedraw 0

nPoly = $#polyIdex
#get number of array


DoLoop k ($nPoly ) 1 -1
   idx = $polyIdex[$k]
   DeleteNavigatorItem $idx
EndLoop 
echo All polygon items have been deleted 
EndMacro
