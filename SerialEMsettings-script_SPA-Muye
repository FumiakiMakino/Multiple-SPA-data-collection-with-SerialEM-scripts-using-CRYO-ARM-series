ScriptName SetFocusAndTrialPosition

# ==============================================================================
# Summary:
# Automatically set Focus (F) and Trial (T) Low Dose positions based on hole vectors
# or reuse previously stored positions for reproducible data collection.
#
# Overview:
# This script determines the Focus and Trial axis positions used in Low Dose mode.
# If a previously saved focus position file (Focus_position.txt) exists in the
# Navigator directory, the script reads the stored distance and angle and applies
# them directly to both Focus and Trial areas to ensure reproducibility.
#
# If the file does not exist, the script calculates the positions automatically
# from the last detected hole vectors. The distance and angle are derived from
# the hole lattice geometry, assuming a symmetric grid, and are then applied to
# both Focus and Trial positions. This allows robust and automated positioning
# without manual intervention.
#
# Date: 2025-12-24
# Author: F.M.
# Affiliation: JEOL Ltd.
# License: MIT License
# ==============================================================================

# ============= Parameters =============
CallFunction EMProperties::LoadAdditionalProperties

# ===================================

ReportNavFile 1
NAVIGATOR_PATH = $RepVal3

DoesFileExist $NAVIGATOR_PATHFocus_position.txt
dofile = $RepVal1

If $dofile == 1
   ReadTextFile vector $NAVIGATOR_PATHFocus_position.txt
   Echo Read Vector from $NAVIGATOR_PATHFocus_position.txt
   holedist = $vector[1]
   holeang = $vector[2]
   
   SetAxisPosition F $holedist $holeang
   SetAxisPosition T $holedist $holeang
Else
   Try 

      SetLowDoseMode 1
      GoToLowDoseArea F

      ReportLastHoleVectors 0 v1x v1y v2x v2y

      dist = SQRT ($v1x * $v1x + $v1y * $v1y) / 2 * 1.41
      ang = ATAN ( $v1y $v1x ) + 45 + $adjust_ang
      ang = MODULO ($ang 90)
      ClearHoleFinder 
      echo Set Focus position distance $dist, angle $ang
      SetAxisPosition F $dist $ang
      SetAxisPosition T $dist $ang 

   Catch 
      echo Error in reading last hole vectors
   EndTry 
Endif 
EndMacro
