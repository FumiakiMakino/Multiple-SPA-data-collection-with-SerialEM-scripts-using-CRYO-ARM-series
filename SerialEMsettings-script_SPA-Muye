def _bufferA_to_uint8_sigma(arr, k=3.0):
    if arr.ndim != 2:
        arr = arr[..., 0]
    arrf = np.asarray(arr, dtype=np.float64)
    finite = np.isfinite(arrf)
    if not finite.any():
        return np.zeros(arr.shape, dtype=np.uint8), 0.0, 0.0, 0.0, 0.0
    vals = arrf[finite]
    mean_val = float(np.mean(vals))
    std_val  = float(np.std(vals, ddof=0))
    vmin = mean_val - k * std_val
    vmax = mean_val + k * std_val
    if not np.isfinite(vmin) or not np.isfinite(vmax) or vmin >= vmax:
        vmin = float(np.min(vals))
        vmax = float(np.max(vals))
        if vmin == vmax:
            return np.zeros(arr.shape, dtype=np.uint8), mean_val, std_val, vmin, vmax
    arrc = np.clip(arrf, vmin, vmax)
    arr8 = ((arrc - vmin) * (255.0 / (vmax - vmin))).astype(np.uint8)
    return arr8, mean_val, std_val, vmin, vmax

