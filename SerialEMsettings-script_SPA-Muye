ScriptName AlignHoleByFindOneHole
# ----------------------------------------------------------------------
# Summary (one line):
# Find one hole in the View image and iteratively center it by applying Image Shift until within tolerance.
#
# What this script does (overview):
# - Repeats up to 'iter_max' times:
#   1) Acquire a View image into buffer A.
#   2) Abort/skip if the image is too dark (mean counts check).
#   3) Detect one hole in buffer A using FindAndCenterOneHole.
#   4) Compute the pixel offset between the detected hole position and the image center.
#   5) Convert that pixel offset to specimen coordinates using:
#      - current camera FOV size, binning, optional K2/K3 scaling factor
#      - CameraToSpecimenMatrix (based on current magnification index)
#   6) If the required shift magnitude is below 'maxholeshift', declare success.
#      Optionally reset Image Shift to (0,0) depending on 'resetIS'.
#   7) Otherwise, apply ResetImageShift and repeat.
# - If it cannot converge within 'ter_max', it marks the Navigator item as skipped and exits.
#
# Notes / cautions:
# - 'maxholeshift' is defined twice in the parameter section; the later value overrides the earlier one.
# - The K2/K3 factor handling (useK23) assumes a 2x scaling when needed; confirm for your camera setup.
# - This method aligns by Image Shift (not stage) and relies on correct calibration of CameraToSpecimenMatrix.
#
# Author: F.M. (JEOL Ltd.) 
# Date: 2025-12-24
#
# License: MIT License
# ----------------------------------------------------------------------
# Align to the hole by FindOneHole
# LowDoseMode must be set up before running this script.
# --------------------------------------------------------------------------------------------------------------------
# <How to run>
# 1. Then just "Run".
#    This uses the hole alignment parameters in "Parameters".
# --------------------------------------------------------------------------------------------------------------------

# ====== Parameters ==========
holesize = 1.2 # [um], hole size
maxholeshift = 2
ter_max = 5 # max iteration
maxholeshift = 0.15 #[um] Threshold for aligning to hole by stage
useK23 = 0  #use K2, k3
resetIS = 0  # 0: not Reset image shift, so apply image shift after align hole.  1: Reset image shift after align hole
# ==========================

it0 = 0

Loop $ter_max it
   View 

   # ======= Judge dark image or not ========
   ReportMeanCounts A
   mean_count = $RepVal1
   If $mean_count < 3
      echo !!!!!!!!!! Failed Hole Alignment  !!!!!!!!!
      skip_message @= "Skipped. align Hole failed"
      CallFunction Funcs::AnnotateSkipItem $skip_message
      SkipAcquiringNavItem 1
      Exit 
   EndIf

   ############# Calculate image shift by FindAndCenterOneHole ##############
   ReportCameraSetArea V
   lenX = $RepVal1
   lenY = $RepVal2
   
   ReportBinning V
   bin = $RepVal1

   ## Find hole and Center a hole ##
   FindAndCenterOneHole A $holesize 0 3

   shiftX = $lenX / 2 - $RepVal1
   shiftY = $lenY / 2 - $RepVal2
   echo --> $it times 
   
   ReportMagIndex 
   magindex = $RepVal1
   CameraToSpecimenMatrix $magindex
   XpX = $RepVal1
   XpY = $RepVal2
   YpX = $RepVal3
   YpY = $RepVal4
   
   factor = 1
   if $useK23 == 1
      factor = 2
   Endif 
   
   Xin = $shiftX * $bin * $factor
   Yin = $shiftY * $bin * $factor * -1
   X = ( $Xin * $XpX + $Yin * $XpY ) * -1
   Y = ( $Xin * $YpX + $Yin * $YpY ) * -1
   echo $X $Y for imageshift
   totalshift = SQRT ( $X * $X + $Y * $Y )  
   If $totalshift < $maxholeshift 
      echo -----  Succeed in hole alignment ------
      if $resetIS == 1
         SetImageShift 0 0
      Endif 

      Break 
   Endif 
    ############# Calculate image shift by FindAndCenterOneHole ##############

   ResetImageShift 

   it0 = $it
EndLoop

If ( $it0 == $ter_max )
   echo !!!!!!!!!! Failed Hole Alignment  !!!!!!!!!
   skip_message @= "Skipped. align Hole failed"
   CallFunction Funcs::AnnotateSkipItem $skip_message
   SkipAcquiringNavItem 1
   Exit 
Endif 

View
EndMacro
