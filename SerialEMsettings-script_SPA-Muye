class _TkViewerThread(threading.Thread):
    def __init__(self):
        super().__init__(daemon=True)
        self.q = queue.Queue()
        self._ready = threading.Event()

    def run(self):
        self.root = tk.Tk()
        self.root.withdraw()  #
        self._ready.set()
        def poll():
            try:
                while True:
                    func, args, kwargs = self.q.get_nowait()
                    try:
                        func(*args, **kwargs)
                    except Exception as e:
                        print("Viewer error:", e)
            except queue.Empty:
                pass
            self.root.after(30, poll)
        self.root.after(30, poll)
        self.root.mainloop()

    def call(self, func, *args, **kwargs):
        self._ready.wait()
        self.q.put((func, args, kwargs))

_viewer = _TkViewerThread()
