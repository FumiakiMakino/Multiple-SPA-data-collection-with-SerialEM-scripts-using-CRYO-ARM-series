Function Core

    CallFunction EMProperties::LoadAdditionalProperties

    # Initialize

    SetBeamBlank 1

    IsVariableDefined FIRSTNAVDONE
    If $repVal1 == 0
        # set FIRSTNAVDONE
        FIRSTNAVDONE := 0
    EndIf 

    #==== Open Beam valve =======
    ReportColumnOrGunValve 
    If $repVal1 == 0
        SetColumnOrGunValve 1
    EndIf 
    #=========================

    ReportMag mag
    ReportLowDose
    isLowDoseOn = $repVal1

    SetLowDoseMode 0
    SetSlitIn 0

    If $mag != $SquareMag
       Call CallSquareMag
    Endif 

EndFunction


Function MoveToSquareCenter
   # =====================================

   loop 1
      #Load the map that the current item was drawnon, into bufferB
      LoadPieceAtNavPoint 0
      Copy A F
      
      #Take View image and Buffer A
      #SetLowDoseMode 1
      #GoToLowDoseArea S
      
      Preview 
      
      #get Image coordinates (cx, cy)
      ReportItemImageCoords 0 F
      
      cx = $RepVal1
      cy = $RepVal2
      okflag = $RepVal3
      
      if ( $okflag < 0)
         Echo Could not transform item to image coordinates on Buf B
         Exit 
      Endif 
      
      AlignBetweenMags F $cx $cy $maxShiftUm $pctScale $inhibitShift 

      ReportAlignShift 
      alishiftx = $RepVal3 * 0.001
      alishifty = $RepVal4 * 0.001

      rad = SQRT ( $alishiftx * $alishiftx + $alishifty * $alishiftx )

      echo $rad

      if ( $thr_shift2maker > 0 ) AND ( $rad > $thr_shift2maker )
         #======Shift item by alignment ===========
         ShiftItemsByAlignment 
         echo ------------ > Do shift-items by align ----------->
      Endif   

      ResetImageShift 
      SetImageShift 0 0
      ReportStageXYZ sx sy sz
      echo stage $sx $sy $sz
   EndLoop 

EndFunction
EndMacro
