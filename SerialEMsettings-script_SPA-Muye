ScriptName AutoFocusScript
# ----------------------------------------------------------------------
# Summary (one line):
# Iterative autofocus helper: measures defocus in Low Dose Focus area, then corrects mainly by Z-stage moves (with tilt-aware Y compensation), and finally runs AutoFocus / updates Navigator Z if possible.
#
# What this script does (overview):
# 1) Moves to Low Dose Focus area (F), records the target defocus, and initializes focus-related state.
# 2) Saves the current stage position (init_x/init_y/init_z) as a safe “return point”.
# 3) Repeats up to max_focus_iter times:
#    - Takes a Focus exposure (G -1) and checks if the image is too dark (mean counts < 3).
#      If dark: mark item skipped and exit.
#    - Reads the measured autofocus value (measured_focus) and computes:
#        defocus  = target_defocus - measured_focus
#        abs_focus = |defocus|
#        setting_z = current_z - measured_focus  (used for safety checks)
#    - If abs_focus <= focus_th:
#        declare success and run AutoFocus, then stop iterating.
#    - Else if abs_focus is unrealistically tiny OR stage Z would be out of safe range:
#        treat as error; return to initial stage position; annotate + skip item; exit.
#    - Else (abs_focus > focus_th):
#        do a Z-stage correction by moving diffz = defocus * 0.8 (a damping factor).
#        If the stage is tilted beyond tilt_th degrees:
#           compensate the Y position by diffy = sin(tilt)*Δz/2 to keep the same area in view.
#        If it reaches the final iteration without converging:
#           annotate + skip item; exit.
# 4) After the loop, it tries to update the Navigator group/item Z values (UpdateGroupZ, UpdateItemZ).
#
# Notes / cautions / improvements:
# - Units: focus_th is annotated [um]. This assumes ReportAutofocus returns microns in the same convention.
# - The condition “abs_focus < 0.001” is treated as an error; that may also happen for a truly perfect focus,
#   so confirm that this is really an indicator of a broken autofocus reading in your setup.
# - “SkipAcquiringNavItem” is called once without an argument near the end:
#     SkipAcquiringNavItem
#   If your SerialEM expects “SkipAcquiringNavItem 1”, this line may fail or do nothing.
# - The script has an “Else: adjust by OL” branch, but it is effectively unreachable because:
#   * If abs_focus <= focus_th -> first branch
#   * Else if abs_focus > focus_th -> stage-move branch
#   So no remaining case is left for the OL branch.
# - “setting_defocus” is used in the OL branch but is never initialized in this script.
#   If you ever re-enable OL correction, initialize setting_defocus first (e.g., ReportDefocus or ReportTargetDefocus baseline).
# - The tilt compensation uses SIN(tiltang)*Δz/2 and applies MoveStage twice. That is probably intentional for backlash/settling,
#   but confirm whether you want the factor “/2” and the double move on your stage.
#
# Author: (as per your convention) T.F. / F.M. (JEOL Ltd.)
# Date: 2025-12-24
# License: MIT License
# ----------------------------------------------------------------------

# =============== Parameters =============== 
focus_th = 0.8 #[um] threthold diffrent defocus value for stagemove 
tilt_th = 1 # threathold applying tilt operation
max_focus_iter = 7
# ========================================= 


echo -------- Start Autofocus --------

GoToLowDoseArea F
ReportTargetDefocus target_defocus
SetEucentricFocus 
ResetDefocus 

ReportStageXYZ init_x init_y init_z

sx = $init_x 
sy = $init_y 
sz = $init_z 

Loop $max_focus_iter iter
   delay 3 sec

   G -1

   ReportMeanCounts A
   mean_count = $repVal1

   If $mean_count < 3
      skip_message @= "Skipped. AF by Z failed"
      SkipAcquiringNavItem 1
      CallFunction Funcs::AnnotateSkipItem $skip_message
      Exit 
   EndIf

   ReportAutofocus measured_focus
   ReportStageXYZ sx sy sz
   setting_z = $sz - $measured_focus
   defocus =  $target_defocus - $measured_focus
   abs_focus = ABS ( $defocus )
   echo  Target Z and measured focus $setting_z $measured_focus
   
   If ($abs_focus <= $focus_th)
      Echo ===> Focusing was succeeded.
      AutoFocus 

      Break 
   ElseIf ( $abs_focus < 0.001 ) OR ( $setting_z > 205 ) OR ( $setting_z < -205 ) 
      echo !!!!!!!!! Error in Autofocus !!!!!!!  You should adjust eucentric height by manual OR obtain new gain-reference
      MoveStageTo $init_x $init_y $init_z
      echo !!!!!!!!! Skip autofocus $setting_z $measured_focus !!!!!!!!!
      skip_message @= "Skipped. AF by Z failed"
      CallFunction Funcs::AnnotateSkipItem $skip_message
      SkipAcquiringNavItem 1
      Exit 
      
      # Ajdust focus by Z for large defocus (>= $focus_error), only at stage is flat
   ElseIf  ( $abs_focus > $focus_th)
      Echo ===> Requires large change.
      Echo ===> Focus is adjusted by stage movement.
      
      diffz = $defocus * 0.8
      MoveStage 0 0 $diffz

      # =============== Tilt operation for z-autofocus =============
      ReportTiltAngle tiltang
      abstilt = ABS ( $tiltang)
      If $abstilt > $tilt_th
         ReportStageXYZ csx csy csz
         diffz2 = $csz - $sz
         echo move stage $sz  to $csz in z
         
         diffy = SIN ( $tiltang ) * $diffz2 / 2
         MoveStage 0 $diffy 0
         MoveStage 0 $diffy 0
      Endif 
      # ========================================


      Echo ---> Move to $sz [um]  $iter times
      Delay 1 sec
      
      If $iter == $max_focus_iter
         echo !!!!!!!!! Skip autofocus $setting_z $measured_focus !!!!!!!!!
         skip_message @= "Skipped. AF by Z failed too large"
         CallFunction Funcs::AnnotateSkipItem $skip_message
         SkipAcquiringNavItem 
         Exit
      EndIf
      
   Else
      Echo ===> Focus is adjusted by OL.
      setting_defocus = $setting_defocus + $defocus
      SetDefocus $setting_defocus
   Endif 
   #      Eucentricity -1 0
   
   
EndLoop 

Try 
   UpdateGroupZ
   UpdateItemZ 
Catch 

   echo Pass to update Z

EndTry 
echo -------- Finished Autofocus --------
EndMacro
