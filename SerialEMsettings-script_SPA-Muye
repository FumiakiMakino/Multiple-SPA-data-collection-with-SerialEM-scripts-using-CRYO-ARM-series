ScriptName AlignHoleByTemplate

# ----------------------------------------------------------------------
# Summary (one line):
# Align the current View image to a previously saved hole-template (buffer T) by template matching, and re-center the Navigator item by stage (ShiftItemsByMicrons); optionally finish with Image Shift.
#
# What this script does (overview):
# 1) Ensures EMProperties additional variables are loaded (LoadAdditionalProperties).
# 2) Ensures a hole-template image exists in the specified buffer (default: T):
#    - If buffer T already has an image, it uses it.
#    - Otherwise it reads 'hole_template.mrc' from the Navigator folder, or falls back to a fixed path.
# 3) Runs iterative hole alignment (up to max_align_iter times):
#    - Takes/updates a View image (Low Dose area V).
#    - Uses AlignTo <template_buffer> to template-match the current View image against the hole template.
#    - Reads the alignment shift (ReportAlignShift), converts it to specimen X/Y (nm) with flip correction.
#    - If the required correction is small enough (< maxholeshift), it declares success.
# 4) When it succeeds, it applies the final correction by moving the Navigator item position:
#    - ShiftItemsByMicrons diff_x diff_y
#    - Also updates accum_item_shiftX/Y so later group changes can be reset consistently.
# 5) Safety/robustness:
#    - If the View image is too dark, the item is marked skipped and acquisition is stopped.
#    - If template matching repeatedly produces huge shifts (>= 500 nm) too many times, it aborts and skips.
#
# Notes / cautions:
# - Units are mixed intentionally:
#   * dx/dy from template match are treated as specimen shift in [nm] (after flip), and holeshift is [nm].
#   * diff_x/diff_y returned by Funcs::GetAppendedShift appear to be in [microns] (since ShiftItemsByMicrons uses microns).
#   Make sure Funcs::GetAppendedShift truly returns microns; otherwise the final ShiftItemsByMicrons would be wrong-scale.
# - Variable name mismatch: the script prints "X:$dx Y:$dy" but the function returns diff_x/diff_y/holeshift/...
#   (It prints $dx/$dy but those are local to DetectHoleAndMove; the Echo lines in AlignToHole probably intended $diff_x/$diff_y.)
# - Template buffer default is T. If T is overwritten elsewhere, alignment will be wrong.
# - The fallback hole template path is hard-coded (hole_file2). Confirm it exists on every system.
# - maxholeshift is defined as 0.2*1000 [um x 1000] which equals 200 [nm] in the same "x1000" convention;
#   but holeshift is computed in [nm]. Confirm the threshold is consistent with holeshift units.
#
# Author: T.F. / F.M. (JEOL Ltd.)
# Date: 2025-12-24
# License: MIT License
# ----------------------------------------------------------------------

# ============================
# Parameters
# ============================

# Threshold for realigning to hole by stage
maxholeshift = 0.2 * 1000 #[um x 1000]

# Maximum iteration for hole alignment
max_align_iter = 10

# Use IS for the final alignment?
align_byIS = 1 # 0:No, 1:Yes

# Template buffer for hole alignment
template_buffer = T


# ============================
# Main
# ============================

# Start hole alignment

CallFunction EMProperties::LoadAdditionalProperties

Try
  Show $template_buffer
  Echo Sucess to read hole-template to $template_buffer
Catch
  CallFunction ReadHoleImage
Endtry


accum_item_shiftX = 0
accum_item_shiftY = 0

CallFunction AlignToHole $maxholeshift $max_align_iter $align_byIS $template_buffer


# ============================
# Functions
# ============================

Function ReadHoleImage 0 0
   
   CallFunction EMProperties::LoadAdditionalProperties
   
   ReportNavFile 1
   NAVIGATOR_PATH = $repVal3
   file_name @= hole_template.mrc
   hole_file1 = $NAVIGATOR_PATH$file_name
   
   path_to_HoleImage @= C:\ProgramData\SerialEM\Data\HoleImage
   hole_file2 = $path_to_HoleImage\tmp_12-13_Au.mrc
   
   # ====== Main =======
   
   Echo ====== Start AlignToHole =======
   
   # Set View mode of LD
   SetLowDoseMode 1
   GoToLowDoseArea V
   
   # Read hole image
   open_again = 0
   
   Echo $template_buffer
   Echo $hole_file2
   
   Try
      ReadOtherFile 0 $template_buffer $hole_file1
   Catch
      Echo ===> Cannot find $hole_file1
      Echo ===> Try to open $hole_file2
      ## Temporaly
      ReadOtherFile 0 $template_buffer $hole_file2
   EndTry 
   
EndFunction


Function AlignToHole 4 1 maxholeshift max_align_iter align_byIS template_buffer

    GoToLowDoseArea V

    process @= AlignToHole

    # Initial settings
    maxholeshift_tmp = $maxholeshift
    align_byIS_tmp = $align_byIS
    
    CallFunction Funcs::SetFlipXY

    ReportImageShift IS_X0 IS_Y0
    ReportSpecimenShift sp_x0 sp_y0
    align_err_count = 0

    LowLimitCount = 0.1 # 10 for k3
    diff_x = 0
    diff_y = 0

    ResetImageShift

    # ======== Start Hole Aliginment ========
    Echo ===> Running AlignToHole ...

    # Take a first View
    V


   # ======= Judge dark image or not ========
   ReportMeanCounts A
   mean_count = $RepVal1
   If $mean_count < 3
      echo !!!!!!!!!! Failed Hole Alignment  !!!!!!!!!
      skip_message @= "Skipped. align Hole failed"
      CallFunction Funcs::AnnotateSkipItem $skip_message
      SkipAcquiringNavItem 1
      Exit 
   EndIf


    # Hole align iterration
    Loop $max_align_iter iter

        ReportMeanCounts
        MeanCountsF = $reportedValue1
        if ( $MeanCountsF < $LowLimitCount )
            echo Counts too low
            Break 
        EndIf

        CallFunction DetectHoleAndMove $iter
        diff_x = $repVal1
        diff_y = $repVal2
        holeshift = $repVal3
        lastShiftX = $repVal4
        lastShiftY = $repVal5

        Echo Hole align iter $iter
        Echo Shift ---> X:$dx [nm] Y:$dy [nm]
        Echo -------------------

        # Success
        If $holeshift < $maxholeshift
            Echo ===> Hole align finished.
            Echo ===> $diff_x $diff_y

            # Realign items
            ShiftItemsByMicrons $diff_x $diff_y
            
            # Accumulated item shift used for reset when group is changed.
            accum_item_shiftX = $accum_item_shiftX - $diff_x
            accum_item_shiftY = $accum_item_shiftY - $diff_y
            diff_x = 0
            diff_y = 0
            
            If $align_byIS == 0
                SetImageShift 0 0 # IS is anyway 8000 8000 for stage shift
            EndIf

            maxholeshift = $maxholeshift_tmp
            align_byIS = $align_byIS_tmp

            Break
        EndIf

    EndLoop 

EndFunction


Function DetectHoleAndMove 2 0 iter

   Echo ===> Hole detection by Template match.
   
   If $iter > 1
      ResetImageShift
      ReportSpecimenShift sp_x0 sp_y0
      V
   EndIf
   
   AlignTo $template_buffer
   ReportAlignShift
   
   dx = $RepVal5 * $flipX # Shift on specimen X axis [nm]
   dy = $RepVal6 * $flipY # Shift on specimen Y axis [nm]
   holeshift = sqrt ( $dx * $dx + $dy * $dy )
   
   # For item realign
   CallFunction Funcs::GetAppendedShift $sp_x0 $sp_y0
   diff_x = $repVal1
   diff_y = $repVal2
   
   If $holeshift >= 500
      align_err_count = $align_err_count + 1
   EndIf
   
   If $align_err_count >= 5
        SetImageShift 0 0
        skip_message @= "Skipped. Hole alignment failure."
        CallFunction Funcs::AnnotateSkipItem $skip_message
        Exit
     EndIf
     
     lastShiftX = $dx / 1000
     lastShiftY = $dy / 1000
     
     return $diff_x $diff_y $holeshift $lastShiftX $lastShiftY 
     
EndFunction
EndMacro
