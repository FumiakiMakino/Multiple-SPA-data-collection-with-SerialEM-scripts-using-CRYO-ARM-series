   holedist = $vector[1]
   holeang = $vector[2]

   delta_x = COS ( $holeang ) * $holedist
   delta_y = SIN ( $holeang ) * $holedist

   echo Movestage --> X Y $delta_x $delta_y 
Else
   Try 

      ReportLastHoleVectors 0 v1x v1y v2x v2y

      dist = SQRT ($v1x * $v1x + $v1y * $v1y) / 2 * 1.41
      ang = ATAN ( $v1y $v1x ) + 45 +$adjust_ang
      ang = MODULO ($ang 90)
      
      delta_x = COS ( $ang ) * $dist 
      delta_y = SIN ( $ang ) * $dist 

      echo Movestage --> X Y $delta_x $delta_y using 
   Catch 
      echo Error in reading last hole vectors
   EndTry 
Endif 


# ===== Run Align to Hole =====
View 

if $whichAlignHole == 0
   Call AlignHoleByFindOneHole
ElseIf $whichAlignHole == 1
   Call AlignHoleByTemplate
