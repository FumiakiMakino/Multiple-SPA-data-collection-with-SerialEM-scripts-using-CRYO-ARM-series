def _replace_in_function_block(full_text: str, func_name: str, replacer):
    """Apply replacer only inside a specific 'Function ... EndFunction' block; fallback to whole text if not found."""
    m_start = re.search(rf'(?m)^\s*Function\s+{re.escape(func_name)}\s*$', full_text)
    if not m_start:
        return replacer(full_text)
    m_end = re.search(r'(?m)^\s*EndFunction\s*$', full_text[m_start.end():])
    if not m_end:
        return replacer(full_text)

    s = m_start.start()
    e = m_start.end() + m_end.end()

    head = full_text[:s]
    block = full_text[s:e]
    tail = full_text[e:]

    new_block = replacer(block)
    return head + new_block + tail


def _replace_in_macro_block_robust(full_text: str, macro_name: str, replacer, debug=False):
    if not isinstance(full_text, str):
        full_text = "" if full_text is None else str(full_text)

    # Split with keepends to reconstruct easily
    lines = full_text.splitlines(keepends=True)

    def _is_scriptname_line(ln: str) -> bool:
        # remove leading spaces; check startswith 'scriptname' (case-insensitive)
        s = ln.lstrip()
        if not s.lower().startswith("scriptname"):
            return False
        # take the rest after 'scriptname'
        rest = s[len("scriptname"):].strip()
        # first word is macro ID; allow comments or extra tokens after
        if not rest:
            return False
        first = rest.split(None, 1)[0]  # first token
        return first.lower() == macro_name.lower()

    def _is_endmacro_line(ln: str) -> bool:
        # Allow "EndMacro", then anything/comments
        s = ln.lstrip()
        return s.lower().startswith("endmacro")

    # locate start
    start_idx = None
    for i, ln in enumerate(lines):
        if _is_scriptname_line(ln):
            start_idx = i
            break
    if start_idx is None:
        if debug:
            print("[macro] start not found for:", macro_name)
        return full_text  # no fallback

    # locate end after start
    end_idx = None
    for j in range(start_idx + 1, len(lines)):
        if _is_endmacro_line(lines[j]):
            end_idx = j
            break
    if end_idx is None:
        if debug:
            print("[macro] EndMacro not found after:", macro_name)
        return full_text  # no fallback

    # Compose head / header / body / footer / tail
    head   = "".join(lines[:start_idx])
    header = lines[start_idx]                # includes newline
    body   = "".join(lines[start_idx+1:end_idx])  # lines between
    footer = lines[end_idx]                  # includes newline
    tail   = "".join(lines[end_idx+1:])

    # Apply replacer to body only
    new_body = replacer(body)
    if not isinstance(new_body, str):
        new_body = "" if new_body is None else str(new_body)

    return head + header + new_body + footer + tail


def _replace_assignments_in_text(script_text, replace_map, case_sensitive=True, debug=False):
    """
    Replace lines of the form:
      <var> = <anything>
      <var> @= <anything>
    Only the RHS is replaced; comments (# ...) are preserved.
    """
    if not isinstance(script_text, str):
        script_text = "" if script_text is None else str(script_text)

    key = (lambda s: s if case_sensitive else s.lower())
    repl_map = {key(k): str(v) for k, v in replace_map.items()}

    def _indent(s: str) -> str:
        m = re.match(r"\s*", s or "")
        return m.group(0) if m else ""

    out_lines = []
    changed_any = False

    for raw_line in script_text.splitlines():
        line = "" if raw_line is None else str(raw_line)
        body, hash_mark, comment = line.partition('#')

        op = None
        idx = -1
        if isinstance(body, str):
            idx = body.find('@=')
            if idx != -1:
                op = '@='
            else:
                idx = body.find('=')
                if idx != -1:
                    op = '='

        if op is None or idx < 0:
            out_lines.append(line)
            continue

        left = body[:idx]
        var = (left or "").strip()
        if not var:
            out_lines.append(line)
            continue

        lk = key(var)
        if lk not in repl_map:
            out_lines.append(line)
            continue

        indent = _indent(left)
        newval = repl_map[lk]
        new_body = f"{indent}{var} {op} {newval}"
        new_line = new_body + (hash_mark + comment if hash_mark else "")
        out_lines.append(new_line)
        changed_any = True

        if debug:
            print(f"[replaced] {var} -> {newval}")

    out = "\n".join(out_lines)
    if script_text.endswith("\n") and not out.endswith("\n"):
        out += "\n"
    return out

def _rewrite_cmd_mag_filenames(block_text: str, values: dict) -> str:
    """
    Inside EMProperties::LoadAdditionalProperties, rewrite only the FILENAME part of:
      cmd_MagAtlas  @= <path>\<old>.txt  -> AtlasMag_<mag_atlas>_Spot<spot_atlas>.txt
      cmd_MagSquare @= <path>\<old>.txt  -> SquareMag_<SquareMag>_Spot<spot_square>.txt
      cmd_MagRecord @= <path>\<old>.txt  -> RecordMag_<Record_mag>_Spot<Record_spot>_Angle<Record_angle>_CLApt<CLapt_for_LDM>.txt
    - Keep directory path as-is
    - Preserve comments (# ...) and whitespace indentation
    - Preserve surrounding quotes of RHS if present
    """

    # --- build new file names from provided values (assume dummy already applied by caller if needed) ---
    mag_atlas   = str(values.get("mag_atlas", "") or "")
    spot_atlas  = str(values.get("spot_atlas", "") or "")
    square_mag  = str(values.get("SquareMag", "") or "")
    spot_square = str(values.get("spot_square", "") or "")
    clapt_ldm   = str(values.get("CLapt_for_LDM", "") or "")
    rec_mag     = str(values.get("Record_mag", "") or "")
    rec_spot    = str(values.get("Record_spot", "") or "")
    rec_angle   = str(values.get("Record_angle", "") or "")

    atlas_file  = f"AtlasMag_{mag_atlas}_Spot{spot_atlas}.txt" if (mag_atlas and spot_atlas) else None
    square_file = f"SquareMag_{square_mag}_Spot{spot_square}.txt" if (square_mag and spot_square) else None
    record_file = (
        f"RecordMag_{rec_mag}_Spot{rec_spot}_Angle{rec_angle}_CLApt{clapt_ldm}.txt"
        if (rec_mag and rec_spot and rec_angle and clapt_ldm) else None
    )

    def _choose_filename(varname: str):
        if varname == "cmd_MagAtlas":
            return atlas_file
        if varname == "cmd_MagSquare":
            return square_file
        if varname == "cmd_MagRecord":
            return record_file
        return None

    def _last_sep_pos(s: str) -> int:
        """Return last index of path separator (\ or /), or -1 if none."""
        bs = s.rfind("\\")
        sl = s.rfind("/")
        return bs if bs > sl else sl

    out_lines = []
    for raw in block_text.splitlines():
        line = "" if raw is None else str(raw)

        # split off comment (preserve # and the rest)
        body, hash_mark, comment = line.partition('#')

        # find operator "@="
        op = "@="
        idx = body.find(op)
        if idx < 0:
            out_lines.append(line)
            continue

        left  = body[:idx]
        right = body[idx + len(op):]

        var = left.strip()
        newfname = _choose_filename(var)
        if newfname is None:
            # not the target variable or insufficient info to build filename
            out_lines.append(line)
            continue

        # prepare RHS: keep quotes if present
        rhs = right.strip()
        quote = ""
        inner = rhs
        if (rhs.startswith('"') and rhs.endswith('"')) or (rhs.startswith("'") and rhs.endswith("'")):
            quote = rhs[0]  # " or '
            if len(rhs) >= 2 and rhs[-1] == quote:
                inner = rhs[1:-1]
            else:
                inner = rhs  # malformed; treat as unquoted

        # split dir and file
        sep_pos = _last_sep_pos(inner)
        if sep_pos >= 0:
            dirpart = inner[:sep_pos+1]
        else:
            dirpart = ""

        # indent from left part (preserve original indentation)
        indent_len = len(left) - len(left.lstrip())
        indent = left[:indent_len]

        # rebuild body with same operator and spacing pattern: "<indent><var> @= <quoted_dir+newfname>"
        new_rhs_inner = dirpart + newfname
        new_rhs = f"{quote}{new_rhs_inner}{quote}" if quote else new_rhs_inner
        new_body = f"{indent}{var} {op} {new_rhs}"

        # reattach comment if existed
        new_line = new_body + (hash_mark + comment if hash_mark else "")
        out_lines.append(new_line)

    out = "\n".join(out_lines)
    if block_text.endswith("\n") and not out.endswith("\n"):
        out += "\n"
    return out


# ---- Model (fields) ----
class FieldVar:
    def __init__(self, default=""):
        self.value = tk.StringVar(value=str(default))
    def get(self):
        return self.value.get().strip()
    def set(self, v):
        self.value.set("" if v is None else str(v))
    def set_safe(self, v):
        self.set(v)

def make_model():
    m = {}
    # Atlas
    m['spot_atlas'] = FieldVar(5)
    m['mag_atlas'] = FieldVar(50)
    m['brightness_atlas'] = FieldVar(100)
    m['CLapt_type'] = FieldVar(1)
    m['CLapt_for_atlas'] = FieldVar(1)
    # Square
    m['SquareMag'] = FieldVar(200)
    m['spot_square'] = FieldVar(4)
    m['brightness_square'] = FieldVar(100)
    m['CLapt_for_square'] = FieldVar(1)
    # LowDose
    for k in ['View','Focus','Trial','Search']:
        m[f'{k}_mag'] = FieldVar("")
        m[f'{k}_angle'] = FieldVar("")
        m[f'{k}_spot'] = FieldVar("")
        m[f'{k}_brightness'] = FieldVar("")
        m[f'{k}_slit'] = FieldVar("")
    # Record (from LowDose)
    m['Record_mag'] = FieldVar("")
    m['Record_spot'] = FieldVar("")
    m['Record_angle'] = FieldVar("")
    m['CLapt_for_record'] = FieldVar(4)
    # Info
    #m['CL_aperture_now'] = FieldVar("N/A")
    return m

# ---- Settings file I/O (INI-like) ----
INI_HEADER = "# SerialEM Settings (INI-like)\n"

def serialize_settings(model):
    """Serialize current model to an INI-like text."""
    lines = [INI_HEADER]
    lines += ["[Atlas]",
              f"spot_atlas={model['spot_atlas'].get()}",
              f"mag_atlas={model['mag_atlas'].get()}",
              f"brightness_atlas={model['brightness_atlas'].get()}",
              f"CLapt_type={model['CLapt_type'].get()}",
              f"CLapt_for_atlas={model['CLapt_for_atlas'].get()}",
              ""]
    lines += ["[Square]",
              f"SquareMag={model['SquareMag'].get()}",
              f"spot_square={model['spot_square'].get()}",
              f"brightness_square={model['brightness_square'].get()}",
              f"CLapt_for_square={model['CLapt_for_square'].get()}",
              ""]
    lines += ["[LowDose_Record]",
              f"Record_mag={model['Record_mag'].get()}",
              f"Record_spot={model['Record_spot'].get()}",
              f"Record_angle={model['Record_angle'].get()}",
              f"CLapt_for_LDM={model['CLapt_for_LDM'].get()}",
              ""]
    for k in ['View','Focus','Trial','Search']:
        lines += [f"[LowDose_{k}]",
                  f"{k}_mag={model[f'{k}_mag'].get()}",
                  f"{k}_angle={model[f'{k}_angle'].get()}",
                  f"{k}_spot={model[f'{k}_spot'].get()}",
                  f"{k}_brightness={model[f'{k}_brightness'].get()}",
                  f"{k}_slit={model[f'{k}_slit'].get()}",
                  ""]
    #lines += ["[Info]",
    #          f"CL_aperture_now={model['CL_aperture_now'].get()}",
    #          ""]
    return "\n".join(lines)

def parse_settings(text, model):
    """Parse INI-like text into model fields."""
    sec = None
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            sec = line[1:-1]; continue
        if "=" in line:
            k, v = [s.strip() for s in line.split("=", 1)]
            if sec == "Atlas" and k in model:
                model[k].set_safe(v)
            elif sec == "Square" and k in model:
                model[k].set_safe(v)
            elif sec == "LowDose_Record" and k in model:
                model[k].set_safe(v)
            elif sec and sec.startswith("LowDose_"):
                if k in model:
                    model[k].set_safe(v)
            elif sec == "Info" and k in model:
                model[k].set_safe(v)

